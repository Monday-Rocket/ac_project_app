default_platform(:ios)

APP_IDENTIFIER = "com.mr.acProjectApp"
EXTENSION_IDENTIFIER = "com.mr.acProjectApp.Extension"
TEAM_ID = "T583WJWNAK"

def profile_name_for(bundle_id)
  # match가 동적으로 생성한 프로파일 이름(뒤에 cert id suffix 포함)을 가져온다.
  ENV["sigh_#{bundle_id}_appstore_profile-name"] || "match AppStore #{bundle_id}"
end

platform :ios do
  desc "Sync certificates and profiles via Match"
  lane :sync_certs do
    setup_ci if is_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || "fastlane/AuthKey.p8",
    )

    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, EXTENSION_IDENTIFIER],
      api_key: api_key,
      readonly: is_ci,
    )
  end

  desc "Build and deploy to TestFlight"
  lane :deploy_testflight do
    setup_ci if is_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || "fastlane/AuthKey.p8",
    )

    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, EXTENSION_IDENTIFIER],
      api_key: api_key,
      readonly: true,
    )

    runner_profile    = profile_name_for(APP_IDENTIFIER)
    extension_profile = profile_name_for(EXTENSION_IDENTIFIER)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: runner_profile,
      bundle_identifier: APP_IDENTIFIER,
      targets: ["Runner"],
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: extension_profile,
      bundle_identifier: EXTENSION_IDENTIFIER,
      targets: ["Extension"],
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      clean: false,
      output_directory: "../build/ios",
      output_name: "Runner.ipa",
      export_options: {
        uploadSymbols: false,
        provisioningProfiles: {
          APP_IDENTIFIER => runner_profile,
          EXTENSION_IDENTIFIER => extension_profile,
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build only (no deploy)"
  lane :build_only do
    setup_ci if is_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || "fastlane/AuthKey.p8",
    )

    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER, EXTENSION_IDENTIFIER],
      api_key: api_key,
      readonly: true,
    )

    runner_profile    = profile_name_for(APP_IDENTIFIER)
    extension_profile = profile_name_for(EXTENSION_IDENTIFIER)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: runner_profile,
      bundle_identifier: APP_IDENTIFIER,
      targets: ["Runner"],
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      profile_name: extension_profile,
      bundle_identifier: EXTENSION_IDENTIFIER,
      targets: ["Extension"],
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      clean: false,
      output_directory: "../build/ios",
      output_name: "Runner.ipa",
      export_options: {
        uploadSymbols: false,
        provisioningProfiles: {
          APP_IDENTIFIER => runner_profile,
          EXTENSION_IDENTIFIER => extension_profile,
        }
      }
    )
  end
end
